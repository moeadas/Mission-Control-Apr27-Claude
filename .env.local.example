# Copy this to .env.local and fill in real values.
# (.env.local is gitignored — never commit secrets.)

# ─── Required ─────────────────────────────────────────────────────────────────
# JWT signing secret. Minimum 32 chars. Generate: openssl rand -base64 48
JWT_SECRET=

# Email of the bootstrap super-admin user. After first signup this user gets the
# super_admin role automatically.
SUPER_ADMIN_EMAIL=

# Self-hosted PostgreSQL connection string.
DATABASE_URL=postgresql://mc_user:CHANGE_ME@localhost:5432/mission_control

# ─── Public app URL (baked into the build) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Scheduled-tasks cron (required for /api/scheduled-tasks/tick) ────────────
# Generate: openssl rand -hex 32
CRON_SECRET=

# ─── Stripe (deferred until production launch) ────────────────────────────────
# Leave STRIPE_ENABLED=false until you're ready. The billing endpoints stay
# disabled and safe in that state.
STRIPE_ENABLED=false
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Provider-secrets encryption ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
# When unset, provider keys are still stored, but unencrypted (dev only).
PROVIDER_SECRETS_MASTER_KEY=

# ─── Optional integrations ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

META_APP_ID=
META_APP_SECRET=

# Optional global Gemini key — used only if a user has not configured their own
# in Settings → AI Providers.
GEMINI_API_KEY=

# ─── Email (transactional invites, password reset) — deferred to Batch G ──────
# RESEND_API_KEY=
# EMAIL_FROM=
