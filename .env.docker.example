# ─── Copy this to .env and fill in real values ────────────────────────────────
# cp .env.docker.example .env

# ─── Database ─────────────────────────────────────────────────────────────────
# Password for the mc_user PostgreSQL account (choose something strong)
DB_PASSWORD=change_me_strong_password_here

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=generate_with_openssl_rand_base64_48

SUPER_ADMIN_EMAIL=moeabuadas@googlemail.com

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ─── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=

# Google PageSpeed Insights API key for SEO / website audits.
PAGESPEED_API_KEY=
